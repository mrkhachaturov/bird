# ---------------------------------------------------------------------------
# Example bird.conf.tmpl — used when BIRD_CONF_TEMPLATE is set.
#
# At container startup, entrypoint.sh runs `envsubst` over this file and
# writes the result to $BIRD_CONF (default /etc/bird/bird.conf). BIRD then
# reads the rendered file, not the template.
#
# Supported placeholders (anything else is passed through verbatim):
#   ${BGP_PASSWORD}       — raw secret string loaded from BGP_PASSWORD or
#                           BGP_PASSWORD_FILE (docker secret)
#   ${BGP_PASSWORD_LINE}  — whole `password "xxx";` statement, OR an empty
#                           string if no password was supplied. Use this
#                           form to keep MD5 auth OPTIONAL in one template.
#
# This file is safe to commit to a public Git repository — the actual
# secret only enters at container startup from a Docker secret.
# ---------------------------------------------------------------------------

log stderr all;
router id 192.0.2.1;

protocol device {}

protocol kernel {
    ipv4 {
        import none;
        export none;
    };
}

template static static_template {
    ipv4;
}

protocol static static_RU     from static_template { include "RU.txt"; }
protocol static static_RU_Max from static_template { include "RU_Max.txt"; }
protocol static static_Google from static_template { include "Google.txt"; }
protocol static static_Meta   from static_template { include "Meta.txt"; }

function tag_ru(int source_code) {
    bgp_community.add((64500, 200));
    bgp_community.add((64500, source_code));
    accept;
}

function tag_service(int service_code) {
    bgp_community.add((64500, service_code));
    accept;
}

filter bgp_out {
    if proto = "static_RU"     then tag_ru(201);
    if proto = "static_RU_Max" then tag_ru(202);
    if proto = "static_Google" then tag_service(102);
    if proto = "static_Meta"   then tag_service(101);
    reject;
}

template bgp bgp_template {
    hold time 240;
    local as 64500;
    ipv4 {
        import none;
        export filter bgp_out;
        next hop self;
    };
}

protocol bgp PEER from bgp_template {
    description "Upstream BGP peer";
    neighbor 198.51.100.1 as 64501;

    # Replaced at startup by either `password "xxx";` or an empty line.
    ${BGP_PASSWORD_LINE}
}
