# ---------------------------------------------------------------------------
# Example bird.conf.tmpl — used when BIRD_CONF_TEMPLATE is set.
#
# Rendered at container startup: `envsubst` replaces placeholders and writes
# the result to $BIRD_CONF. BIRD then reads the rendered file.
#
# Supported placeholders:
#   ${BGP_PASSWORD}       — raw secret string from BGP_PASSWORD[_FILE]
#   ${BGP_PASSWORD_LINE}  — the whole `password "xxx";` statement, OR an
#                           empty string when no password was supplied.
#                           Use this form to keep MD5 auth OPTIONAL.
# Anything else starting with `$` passes through verbatim.
#
# Also demonstrates the MULTIPLE-EXPORT-FILTERS pattern — see `filter …`
# blocks and the two `protocol bgp …` peers at the bottom.
#
# This file is safe to commit to a public Git repository — no secret lives
# in it, only placeholder names.
# ---------------------------------------------------------------------------

log stderr all;
router id 192.0.2.1;

protocol device {}

protocol kernel {
    ipv4 {
        import none;
        export none;
    };
}

template static static_template {
    ipv4;
}

protocol static static_RU     from static_template {
    include "RU.txt";
}
protocol static static_RU_Max from static_template {
    include "RU_Max.txt";
}
protocol static static_Google from static_template {
    include "Google.txt";
}
protocol static static_Meta   from static_template {
    include "Meta.txt";
}

function tag_ru(int source_code) {
    bgp_community.add((64500, 200));
    bgp_community.add((64500, source_code));
    accept;
}

function tag_service(int service_code) {
    bgp_community.add((64500, service_code));
    accept;
}

# Full feed — RU + all service groups.
filter bgp_out_full {
    if proto = "static_RU"     then tag_ru(201);
    if proto = "static_RU_Max" then tag_ru(202);
    if proto = "static_Google" then tag_service(102);
    if proto = "static_Meta"   then tag_service(101);
    reject;
}

# Minimal feed — RU only, no service lists.
filter bgp_out_ru_only {
    if proto = "static_RU"     then tag_ru(201);
    if proto = "static_RU_Max" then tag_ru(202);
    reject;
}

template bgp bgp_template {
    hold time 240;
    local as 64500;

    # REQUIRED when bird runs inside a Docker bridge/overlay network:
    # the container's interfaces are 172.x.x.x, so peers on 10.x/192.168.x
    # aren't directly-connected neighbors from bird's point of view.
    # Without `multihop`, bird silently sits in BGP Idle ("Waiting for X to
    # become my neighbor" — trace-level only, invisible at info logging).
    # Safe to keep even with host networking or native installs.
    # See README → Troubleshooting → "BGP stays in Idle state forever".
    multihop 10;

    ipv4 {
        import none;
        next hop self;
    };
}

protocol bgp PEER_FULL from bgp_template {
    description "Upstream that gets everything (RU + services)";
    neighbor 198.51.100.1 as 64501;
    ipv4 { export filter bgp_out_full; };

    # The placeholder below is replaced at container startup — either with
    # `password "xxx";` or with an empty string (see CHANGELOG v0.1.1).
    ${BGP_PASSWORD_LINE}
}

protocol bgp PEER_RU from bgp_template {
    description "Upstream that gets RU only";
    neighbor 198.51.100.2 as 64502;
    ipv4 { export filter bgp_out_ru_only; };
    ${BGP_PASSWORD_LINE}
}
