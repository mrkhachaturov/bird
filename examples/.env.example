# Copy to .env and fill in your values.

# MaxMind credentials (GeoLite2 — free account at account.maxmind.com).
# Use either plain env vars OR the *_FILE convention (for docker secrets).
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
# MAXMIND_ACCOUNT_ID_FILE=/run/secrets/maxmind_account_id
# MAXMIND_LICENSE_KEY_FILE=/run/secrets/maxmind_license_key

# Downloader role. auto = true if creds set, else false.
#   true  = container downloads MaxMind CSV (updater role)
#   false = never download; MAXMIND_CSV_DIR must be populated externally
#   auto  = derive from presence of creds
MAXMIND_UPDATE=auto

# Cache dir for the MaxMind Country-CSV bundle.
MAXMIND_CSV_DIR=/var/cache/maxmind

# Optional override (if MaxMind moves the URL again, or you want another edition).
MAXMIND_DOWNLOAD_URL=

# Main fetch loop cadence (url + asn sources).
REFRESH_INTERVAL=24h

# How often MaxMind may be re-downloaded (weekly release cadence).
MAXMIND_REFRESH_INTERVAL=7d

# One-shot mode — fetch + validate config then exit. Useful for CI.
RUN_ONCE=false

# Webhook server — enabled only when WEBHOOK_SECRET is set.
# GitHub-compatible (HMAC-SHA256 via X-Hub-Signature-256).
WEBHOOK_SECRET=
WEBHOOK_PORT=9090
